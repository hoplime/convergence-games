<Page>
    {% block content %}
        <PageTitle>Profile</PageTitle>
        <PageContainer>
            <form class="flex flex-col gap-4" id="profile-form" hx-post="/profile" hx-target="#content">
                <button type="submit" disabled class="hidden" aria-hidden="true"></button>
                <FieldsetBase>
                    <legend class="fieldset-legend">Public Information</legend>
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label class="fieldset-label">First name</label>
                            <input
                                type="text"
                                class="input w-full"
                                name="first_name"
                                value="{{ profile_user.first_name }}"
                                required
                            />
                        </div>
                        <div>
                            <label class="fieldset-label">Last name</label>
                            <input
                                type="text"
                                class="input w-full"
                                name="last_name"
                                value="{{ profile_user.last_name }}"
                            />
                        </div>
                    </div>
                    <label class="fieldset-label">Bio</label>
                    <TipTap form_input_name="description" :initial_content_json="profile_user.description" />
                    <label class="flex items-center gap-2">
                        <input
                            type="checkbox"
                            class="checkbox"
                            name="over_18"
                            {{ "checked" if profile_user.over_18 }}
                        />
                        <span>I am 18+</span>
                        <span class="text-sm text-base-content/50">(required to join R18 games)</span>
                    </label>
                </FieldsetBase>
                <div
                    _="on change from #profile-form or keyup from #profile-form remove .hidden from me"
                    class="grid hidden w-full grid-cols-2 gap-4"
                >
                    <button class="btn btn-neutral" type="button" hx-get="/profile" hx-target="#content">
                        Discard
                    </button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
            <FieldsetBase>
                <legend class="fieldset-legend">Accounts</legend>
                <ul class="list">
                    {% for key in ['email', 'discord', 'google'] %}
                        {% if key in user_logins %}
                            {% for user_login in user_logins[key] %}
                                <li class="list-row flex items-center gap-3">
                                    <img
                                        src="/static/icons/logos/{{ key }}.svg"
                                        class="size-8 shrink-0"
                                        alt="{{ key.capitalize() }} Logo"
                                    />
                                    <div class="min-w-0 flex-1">
                                        <div class="font-medium">{{ key.capitalize() }}</div>
                                        <div class="truncate text-sm text-base-content/70">
                                            {{ user_login.provider_email }}
                                        </div>
                                    </div>
                                    <div class="badge shrink-0 badge-success">Connected</div>
                                </li>
                            {% endfor %}
                        {% else %}
                            <li class="list-row flex items-center gap-3">
                                <img
                                    src="/static/icons/logos/{{ key }}.svg"
                                    class="size-8 shrink-0 opacity-40"
                                    alt="{{ key.capitalize() }} Logo"
                                />
                                <div class="min-w-0 flex-1">
                                    <div class="font-medium text-base-content/50">{{ key.capitalize() }}</div>
                                </div>
                                {% if key == 'email' %}
                                    <a
                                        href="/email-sign-in?linking_account_sqid={{ swim(request.user) }}"
                                        hx-boost="true"
                                        class="btn shrink-0 btn-sm btn-primary"
                                        >Link</a
                                    >
                                {% elif key == 'discord' %}
                                    <a
                                        href="/oauth2/discord/login?linking_account_sqid={{ swim(request.user) }}"
                                        class="btn shrink-0 btn-sm btn-primary"
                                        >Link</a
                                    >
                                {% elif key == 'google' %}
                                    <a
                                        href="/oauth2/google/login?linking_account_sqid={{ swim(request.user) }}"
                                        class="btn shrink-0 btn-sm btn-primary"
                                        >Link</a
                                    >
                                {% endif %}
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
                <button class="btn self-start btn-sm btn-error" hx-post="/oauth2/logout" hx-target="#content">
                    Logout
                </button>
            </FieldsetBase>
            <Sessions :sessions="sessions" :current_session_jti="current_session_jti" />
        </PageContainer>
    {% endblock %}
</Page>
