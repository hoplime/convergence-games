<Page>
    {% block content %}
        <PageTitle>{{ event.name }} Games</PageTitle>
        <PageContainer size="max-w-screen-2xl">
            <h2 class="text-xl">{{ event.name }} Games</h2>

            <div class="drawer">
                <input id="filter_drawer" type="checkbox" class="drawer-toggle" />

                {# Main content #}
                <div class="drawer-content flex flex-col gap-2">
                    {# Filter toggle + active pills #}
                    <div class="flex flex-wrap items-center gap-2">
                        <label for="filter_drawer" class="drawer-button btn btn-outline">
                            <span class="icon-[mingcute--filter-fill]"></span>
                            <span
                                id="filter_drawer_label"
                                _="
                                on load or change from #filter_form or change from closest .drawer
                                set count to #filter_form.querySelectorAll('input[type=checkbox][name]:checked').length
                                if count > 0
                                    set my textContent to 'Filters (' + count + ')'
                                else
                                    set my textContent to 'Filters'
                                end
                                "
                                >Filters</span
                            >
                        </label>
                    </div>

                    {# Game grid #}
                    <div class="grid grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="game_list">
                        {% block game_list %}
                            {% for game in games %}
                                <GameCard
                                    :game="game"
                                    :preference="preferences.get(game.id)"
                                    :user_game_played="user_game_playeds.get(game.id)"
                                    :scheduled_time_slot_ids="scheduled_time_slots.get(game.id, [])"
                                    :display_d20="latest_d20_transaction is not none and latest_d20_transaction.current_balance > 0"
                                />
                            {% endfor %}
                            {% if not games %}
                                <div class="card col-span-full rounded-box border border-base-300 bg-base-200">
                                    <div class="card-body">
                                        <h2 class="card-title text-xl">No Games Found</h2>
                                        <p>There are no games that match your search criteria.</p>
                                        <p>Try changing your filters or check back later!</p>
                                    </div>
                                </div>
                            {% endif %}
                        {% endblock %}
                    </div>

                    {% if request.user is not none %}
                        {% if request.user | has_permission("event", (event, event), "manage_submissions") %}
                            <AdminSectionCard :event="event" />
                        {% endif %}
                    {% endif %}
                </div>

                {# Filter drawer #}
                <div class="drawer-side z-20">
                    <label for="filter_drawer" aria-label="close sidebar" class="drawer-overlay"></label>
                    <form
                        id="filter_form"
                        hx-get="/event/{{ swim(event) }}/games"
                        hx-target="#game_list"
                        hx-push-url="true"
                        hx-trigger="change delay:100ms, reset delay:10ms"
                        hx-params="not _search_genre, _search_system, _search_content"
                        class="flex min-h-full w-72 flex-col gap-2 bg-base-200 p-4 md:w-80 lg:w-96"
                    >
                        <div class="flex items-center justify-between">
                            <span class="text-lg font-bold">Filters</span>
                            <button
                                type="button"
                                class="btn btn-outline btn-xs btn-error"
                                _="on click call #filter_form.reset() then send change to #filter_form"
                            >
                                <span class="icon-[mdi--filter-off-outline]"></span>
                                Clear all
                            </button>
                        </div>

                        {# Active filter pills #}
                        <div
                            id="active_filter_pills"
                            class="flex flex-wrap gap-2"
                            _="
                            on load or change from #filter_form
                                set checkedCbs to #filter_form.querySelectorAll('input[type=checkbox][name]:checked')
                                set my innerHTML to ''
                                for cb in checkedCbs
                                    make a <span.badge.badge-md.gap-1.cursor-pointer/>
                                    if cb.name is 'session'
                                        add .badge-info to it
                                    else if cb.name is 'content'
                                        add .badge-warning to it
                                        set it.textContent to 'Exclude: ' + cb.parentElement.textContent.trim() + ' ×'
                                    else if cb.name is 'preference'
                                        add .badge-secondary to it
                                    else
                                        add .badge-primary to it
                                    end
                                    if it.textContent is ''
                                        set it.textContent to cb.parentElement.textContent.trim() + ' ×'
                                    end
                                    set it's @data-name to cb.name
                                    set it's @data-value to cb.value
                                    put it at end of me
                                end
                            end

                            on click
                                if target.dataset.name
                                    for cb in #filter_form.querySelectorAll('input[type=checkbox][name]')
                                        if cb.name is target.dataset.name and cb.value is target.dataset.value
                                            set cb.checked to false
                                            send change to cb
                                        end
                                    end
                                end
                            end
                            "
                        ></div>

                        {% if event.is_planner_open() %}
                            <FilterSection :form_data="form_data.session" />
                        {% endif %}
                        <FilterSection :form_data="form_data.genre" :searchable="true" />
                        <FilterSection :form_data="form_data.system" :searchable="true" />
                        <FilterSection :form_data="form_data.tone" />
                        <FilterSection :form_data="form_data.bonus" />
                        <FilterSection :form_data="form_data.content" :searchable="true" />
                        {% if request.user is not none and event.is_preferences_open() %}
                            <FilterSection :form_data="form_data.preference" />
                        {% endif %}

                    </form>
                </div>
            </div>
        </PageContainer>
    {% endblock %}
</Page>
