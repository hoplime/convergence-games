<Page>
    {% block content %}
        <PageTitle>{{ event.name }} Games</PageTitle>
        <PageContainer size="max-w-screen-2xl">
            <h2 class="text-xl">{{ event.name }} Games</h2>

            <div class="drawer lg:drawer-open">
                <input id="filter_drawer" type="checkbox" class="drawer-toggle" />

                {# Main content #}
                <div class="drawer-content flex flex-col gap-2">
                    {# Mobile filter toggle + active pills #}
                    <div class="flex flex-wrap items-center gap-2 lg:hidden">
                        <label
                            for="filter_drawer"
                            class="drawer-button btn btn-outline btn-sm"
                            id="filter_drawer_button"
                            _="
                            on load or change from #filter_form
                            set count to #filter_form.querySelectorAll('input[type=checkbox]:checked').length
                            if count > 0
                                set my textContent to 'Filters (' + count + ')'
                            else
                                set my textContent to 'Filters'
                            end
                            "
                        >
                            Filters
                        </label>
                    </div>

                    {# Active filter pills (visible when sidebar is hidden on mobile) #}
                    <div
                        id="active_filter_pills_mobile"
                        class="flex flex-wrap gap-1 lg:hidden"
                        _="
                        on load or change from #filter_form
                            log 'pills_mobile: rebuilding pills'
                            set checkedCbs to #filter_form.querySelectorAll('input[type=checkbox]:checked')
                            log `pills_mobile: found ${checkedCbs.length} checked`
                            set my innerHTML to ''
                            for cb in checkedCbs
                                log `pills_mobile: pill for ${cb.name}=${cb.value} id=${cb.id}`
                                make a <button.badge.badge-sm.badge-primary.gap-1.cursor-pointer/>
                                set it.textContent to cb.parentElement.textContent.trim() + ' ×'
                                set it's @data-cb to cb.id
                                put it at end of me
                            end
                        end

                        on click
                            log `pills_mobile: click on ${target.tagName} data-cb=${target.dataset.cb}`
                            if target.dataset.cb
                                set cb to #{target.dataset.cb}
                                log `pills_mobile: unchecking ${cb.id}`
                                set cb.checked to false
                                send change to cb
                            end
                        end
                        "
                    ></div>

                    {# Game grid #}
                    <div class="grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4" id="game_list">
                        {% block game_list %}
                            {% for game in games %}
                                <GameCard
                                    :game="game"
                                    :preference="preferences.get(game.id)"
                                    :user_game_played="user_game_playeds.get(game.id)"
                                    :scheduled_time_slot_ids="scheduled_time_slots.get(game.id, [])"
                                    :display_d20="latest_d20_transaction is not none and latest_d20_transaction.current_balance > 0"
                                />
                            {% endfor %}
                            {% if not games %}
                                <div class="card col-span-full rounded-box border border-base-300 bg-base-200">
                                    <div class="card-body">
                                        <h2 class="card-title text-xl">No Games Found</h2>
                                        <p>There are no games that match your search criteria.</p>
                                        <p>Try changing your filters or check back later!</p>
                                    </div>
                                </div>
                            {% endif %}
                        {% endblock %}
                    </div>

                    {% if request.user is not none %}
                        {% if request.user | has_permission("event", (event, event), "manage_submissions") %}
                            <AdminSectionCard :event="event" />
                        {% endif %}
                    {% endif %}
                </div>

                {# Filter sidebar / drawer #}
                <div class="drawer-side z-20">
                    <label for="filter_drawer" aria-label="close sidebar" class="drawer-overlay"></label>
                    <form
                        id="filter_form"
                        hx-get="/event/{{ swim(event) }}/games"
                        hx-target="#game_list"
                        hx-push-url="true"
                        hx-trigger="change delay:100ms, reset delay:10ms"
                        hx-params="not _search_genre, not _search_system, not _search_content"
                        class="flex min-h-full w-72 flex-col gap-2 bg-base-200 p-4"
                    >
                        <div class="flex items-center justify-between">
                            <span class="text-lg font-bold">Filters</span>
                            <button
                                type="button"
                                class="btn btn-ghost btn-xs"
                                _="on click get #filter_form then it.reset()"
                            >
                                Clear all
                            </button>
                        </div>

                        {% if event.is_planner_open() %}
                            <FilterSection :form_data="form_data.session" />
                        {% endif %}
                        <FilterSection :form_data="form_data.genre" :searchable="true" />
                        <FilterSection :form_data="form_data.system" :searchable="true" />
                        <FilterSection :form_data="form_data.tone" />
                        <FilterSection :form_data="form_data.bonus" />
                        <FilterSection :form_data="form_data.content" :searchable="true" />
                        {% if request.user is not none and event.is_preferences_open() %}
                            <FilterSection :form_data="form_data.preference" />
                        {% endif %}

                        {# Active filter pills in sidebar #}
                        <div
                            id="active_filter_pills"
                            class="flex flex-wrap gap-1"
                            _="
                            on load or change from #filter_form
                                log 'pills_sidebar: rebuilding pills'
                                set checkedCbs to #filter_form.querySelectorAll('input[type=checkbox]:checked')
                                log `pills_sidebar: found ${checkedCbs.length} checked`
                                set my innerHTML to ''
                                for cb in checkedCbs
                                    log `pills_sidebar: pill for ${cb.name}=${cb.value} id=${cb.id}`
                                    make a <button.badge.badge-sm.badge-primary.gap-1.cursor-pointer/>
                                    set it.textContent to cb.parentElement.textContent.trim() + ' ×'
                                    set it's @data-cb to cb.id
                                    put it at end of me
                                end
                            end

                            on click
                                log `pills_sidebar: click on ${target.tagName} data-cb=${target.dataset.cb}`
                                if target.dataset.cb
                                    set cb to #{target.dataset.cb}
                                    log `pills_sidebar: unchecking ${cb.id}`
                                    set cb.checked to false
                                    send change to cb
                                end
                            end
                            "
                        ></div>
                    </form>
                </div>
            </div>
        </PageContainer>
    {% endblock %}
</Page>
