<Page>
    {% block content %}
        <title>{{ SETTINGS.SITE_TITLE }}</title>
        <PageContainer>
            <div class="flex flex-col items-center gap-6 py-12 text-center">
                <h1 class="text-4xl font-bold">Convergence</h1>
                <p class="text-lg text-base-content/70">
                    Site under construction. More details coming soon.
                </p>
                <div class="flex flex-col gap-4 w-full max-w-sm">
                    <a href="/submit-game" class="btn btn-xl btn-primary">Submit a Game</a>
                    <a href="/sign-up" class="btn btn-xl btn-secondary">Sign Up</a>
                    <a href="/faq" class="btn btn-xl btn-ghost">FAQ</a>
                </div>
            </div>
        </PageContainer>
    {% endblock %}
</Page>
