<Page>
    {% block content %}
        <PageTitle>{{ event.name }} Planner</PageTitle>
        <PageContainer>
            <div class="flex flex-col items-center gap-4 py-8 text-center">
                <span class="icon-[mdi--calendar-clock] text-6xl text-base-content/30"></span>
                <h2 class="text-xl font-bold">Session planner isn't open yet</h2>
                <p class="max-w-md text-base-content">
                    The session schedule hasn't been finalised and party planning isn't open yet for {{ event.name }}.
                </p>
                {% if event.planner_open_at %}
                    <p class="text-base-content">
                        The planner opens <TimeDisplay :time="event.planner_open_at" :date="true" />.
                    </p>
                {% endif %}
                <div class="flex flex-col gap-2">
                    {% if event.is_preferences_open() %}
                        <p class="text-base-content">
                            In the meantime, you can browse the games and set your preferences.
                        </p>
                        <a href="/event/{{ swim(event) }}/games" class="btn btn-primary">
                            <span class="icon-[bi--dice-6-fill]"></span>
                            Browse games & set preferences
                        </a>
                    {% else %}
                        <p class="text-base-content">In the meantime, you can browse the games available.</p>
                        <a href="/event/{{ swim(event) }}/games" class="btn btn-primary">
                            <span class="icon-[bi--dice-6-fill]"></span>
                            Browse games
                        </a>
                    {% endif %}
                </div>
            </div>
        </PageContainer>
    {% endblock %}
</Page>
