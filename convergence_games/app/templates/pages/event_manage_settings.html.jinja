<Page>
    {% block content %}
        <PageTitle>{{ event.name }} Settings</PageTitle>
        <PageContainer>
            <h2 class="text-xl font-bold">Event Time Windows</h2>
            <p class="mb-4 text-base-content">
                Control when features become available. Leave blank to use defaults (submissions/editing always open;
                preferences/planner closed until set). All times in <strong>{{ event.timezone }}</strong>.
            </p>

            {% macro dt_value(dt_utc) %}{{ dt_utc.astimezone(tz).strftime('%Y-%m-%dT%H:%M') if dt_utc else '' }}{% endmacro %}
            {% macro status_badge(is_open) %}
                {% if is_open %}
                    <div class="badge badge-success">Open</div>
                {% else %}
                    <div class="badge badge-error">Closed</div>
                {% endif %}
            {% endmacro %}

            <form
                method="post"
                hx-put="/event/{{ swim(event) }}/manage-settings"
                hx-swap="none"
                class="flex flex-col gap-4"
            >
                <FieldsetBase>
                    <legend class="fieldset-legend">Game Masters</legend>
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                        <label class="form-control w-full">
                            <div class="label">
                                <span class="label-text">Submissions open</span>
                                {{ status_badge(event.is_submissions_open()) }}
                            </div>
                            <input
                                type="datetime-local"
                                name="submissions_open_at"
                                class="input-bordered input w-full"
                                value="{{ dt_value(event.submissions_open_at) }}"
                            />
                        </label>
                        <label class="form-control w-full">
                            <div class="label"><span class="label-text">Submissions close</span></div>
                            <input
                                type="datetime-local"
                                name="submissions_close_at"
                                class="input-bordered input w-full"
                                value="{{ dt_value(event.submissions_close_at) }}"
                            />
                        </label>
                        <label class="form-control w-full">
                            <div class="label">
                                <span class="label-text">Editing closes</span>
                                {{ status_badge(event.is_editing_open()) }}
                            </div>
                            <input
                                type="datetime-local"
                                name="editing_close_at"
                                class="input-bordered input w-full"
                                value="{{ dt_value(event.editing_close_at) }}"
                            />
                        </label>
                    </div>
                </FieldsetBase>

                <FieldsetBase>
                    <legend class="fieldset-legend">Players</legend>
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <label class="form-control w-full">
                            <div class="label">
                                <span class="label-text">Preferences open</span>
                                {{ status_badge(event.is_preferences_open()) }}
                            </div>
                            <input
                                type="datetime-local"
                                name="preferences_open_at"
                                class="input-bordered input w-full"
                                value="{{ dt_value(event.preferences_open_at) }}"
                            />
                        </label>
                        <label class="form-control w-full">
                            <div class="label">
                                <span class="label-text">Planner open</span>
                                {{ status_badge(event.is_planner_open()) }}
                            </div>
                            <input
                                type="datetime-local"
                                name="planner_open_at"
                                class="input-bordered input w-full"
                                value="{{ dt_value(event.planner_open_at) }}"
                            />
                        </label>
                    </div>
                </FieldsetBase>

                <button type="submit" class="btn btn-primary">Save Settings</button>
            </form>
        </PageContainer>
    {% endblock %}
</Page>
