                    </li>
                    <li>
                        <a href="/settings">Settings</a>
                    </li>
                    <li></li>
                    <li>
                        <a hx-post="/oauth2/logout" hx-target="#content" hx-push-url="true">Logout</a>
                    </li>
                {% else %}
                    <li class="menu-title">Not Logged In</li>
                    <li>
                        <a href="/sign-up">Sign Up</a>
                    </li>
                    <li>
                        <a href="/sign-in">Sign In</a>
                    </li>
                {% endif %}
            </ul>
        </div>
